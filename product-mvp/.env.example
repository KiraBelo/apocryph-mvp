DATABASE_URL=postgresql://user:password@localhost:5432/apocryph

# SESSION_SECRET: обязательно сгенерируй реальный секрет перед запуском.
# Любое значение, содержащее "change-this", "example", "placeholder" и т.п. —
# сервер откажется стартовать (защита от случайного деплоя с placeholder-секретом).
#
# Сгенерировать:  openssl rand -base64 48
#          или:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=
