DATABASE_URL=postgresql://user:password@localhost:5432/apocryph

# SESSION_SECRET: обязательно сгенерируй реальный секрет перед запуском.
# Любое значение, содержащее "change-this", "example", "placeholder" и т.п. —
# сервер откажется стартовать (защита от случайного деплоя с placeholder-секретом).
#
# Сгенерировать:  openssl rand -base64 48
#          или:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# TRUSTED_PROXY: ставь "1" ТОЛЬКО когда приложение действительно стоит за
# доверенным reverse-proxy (nginx/Cloudflare), который перезаписывает
# X-Forwarded-For. На проде Апокрифа это nginx — поэтому в боевом .env.local
# должно быть TRUSTED_PROXY=1.
#
# Без этой переменной rate limit группирует всех клиентов в один ключ 'anon':
# защита от DoS остаётся, но юзеры с одного nginx будут блокировать друг
# друга за один логин. С TRUSTED_PROXY=1 без реального прокси — наоборот,
# любой клиент сможет подделать X-Forwarded-For и обойти rate limit.
#
# Правило: если перед Next.js стоит nginx с `proxy_set_header X-Forwarded-For`
# — ставь 1. Если запускаешь напрямую (next start без прокси) — оставь
# пустым. См. src/lib/client-ip.ts.
TRUSTED_PROXY=

# NEXT_PUBLIC_BASE_URL: публичный URL приложения, на который выполняются
# редиректы (например, после logout). На проде должно быть выставлено в
# реальный домен (например, https://apocryph.example.com); если переменной
# нет, logout берёт хост из самого запроса — это ок, но явное значение
# упрощает диагностику.
NEXT_PUBLIC_BASE_URL=
